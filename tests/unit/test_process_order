import json
import pytest
from unittest.mock import Mock, patch
import os
import sys
from moto import mock_aws

@pytest.fixture
def lambda_context():
    context = Mock()
    context.request_id = 'test-request-id'
    return context

@mock_aws
@patch('time.sleep') 
def test_process_order_success(mock_sleep, lambda_context):
    """Test successful order processing"""
    
    os.environ['DYNAMODB_TABLE'] = 'test-orders'
    os.environ['SNS_TOPIC_ARN'] = 'arn:aws:sns:us-east-1:123456789012:test-topic'
    os.environ['AWS_DEFAULT_REGION'] = 'us-east-1'
    
    sys.path.insert(0, os.path.join(os.path.dirname(__file__), '../../src/lambda/process-order'))
    import index
    
    import boto3
   
    dynamodb = boto3.resource('dynamodb', region_name='us-east-1')
    table = dynamodb.create_table(
        TableName='test-orders',
        KeySchema=[{'AttributeName': 'order_id', 'KeyType': 'HASH'}],
        AttributeDefinitions=[{'AttributeName': 'order_id', 'AttributeType': 'S'}],
        BillingMode='PAY_PER_REQUEST'
    )
    
    table.put_item(Item={
        'order_id': 'TEST_001',
        'customer_id': 'CUST_123',
        'total': '99.99',
        'status': 'PENDING'
    })

    sns = boto3.client('sns', region_name='us-east-1')
    topic = sns.create_topic(Name='test-topic')

    event = {
        'Records': [{
            'body': json.dumps({
                'order_id': 'TEST_001',
                'customer_id': 'CUST_123',
                'total': 99.99
            })
        }]
    }

    index.lambda_handler(event, lambda_context)

    result = table.get_item(Key={'order_id': 'TEST_001'})
    assert result['Item']['status'] == 'COMPLETED'

    assert mock_sleep.call_count == 3